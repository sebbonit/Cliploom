{
  "name": "cliploom",
  "version": "1.0.0",
  "description": "Craft polished GIF and WebP loops from screen recordings",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "author": "Cliploom",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run dev:electron\"",
    "dev:electron": "tsc -p tsconfig.electron.json && wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "start": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "dist": "npm run build && env -u ELECTRON_RUN_AS_NODE electron-builder",
    "dist:mac": "npm run build && env -u ELECTRON_RUN_AS_NODE electron-builder --mac"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-installer": "^2.1.5",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.cliploom.app",
    "productName": "Cliploom",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/@ffprobe-installer/darwin-arm64/**"
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    }
  }
}
